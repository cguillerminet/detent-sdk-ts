{
  "name": "@detent/sdk",
  "version": "0.1.1",
  "description": "Typed TypeScript client for the Detent rate-limiting API.",
  "license": "MIT",
  "keywords": [
    "rate-limit",
    "rate-limiter",
    "detent",
    "sdk",
    "api-client",
    "ratelimit"
  ],
  "homepage": "https://github.com/cguillerminet/detent-sdk-ts#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/cguillerminet/detent-sdk-ts.git"
  },
  "bugs": {
    "url": "https://github.com/cguillerminet/detent-sdk-ts/issues"
  },
  "type": "module",
  "engines": {
    "node": ">=18"
  },
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "files": [
    "dist"
  ],
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsup",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "gen:types": "tsx scripts/gen-types.ts",
    "prepublishOnly": "npm run build"
  },
  "devDependencies": {
    "@types/node": "^20.11.0",
    "openapi-typescript": "^7.4.0",
    "tsup": "^8.0.0",
    "tsx": "^4.7.0",
    "typescript": "^5.4.0",
    "vitest": "^1.4.0"
  }
}
