{
  "name": "@detent/sdk",
  "version": "0.1.0",
  "description": "Typed TypeScript client for the Detent rate-limiting API.",
  "license": "MIT",
  "type": "module",
  "engines": { "node": ">=18" },
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "files": ["dist"],
  "scripts": {
    "build": "tsup",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "gen:types": "tsx scripts/gen-types.ts"
  },
  "devDependencies": {
    "@types/node": "^20.11.0",
    "openapi-typescript": "^7.4.0",
    "tsup": "^8.0.0",
    "tsx": "^4.7.0",
    "typescript": "^5.4.0",
    "vitest": "^1.4.0"
  }
}
